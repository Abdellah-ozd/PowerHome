<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/notif_title"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        android:layout_marginBottom="24dp"/>

    <androidx.appcompat.widget.SwitchCompat
        android:id="@+id/switch_master_notif"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/notif_master"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#2C3E50"
        app:switchTextAppearance="@style/TextAppearance.AppCompat.Medium"
        android:layout_marginBottom="16dp"/>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#D1D8E0"
        android:layout_marginBottom="16dp"/>

    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="12dp"
        app:cardElevation="2dp">

        <LinearLayout
            android:id="@+id/layout_sub_notifs"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp"
            android:background="@android:color/white">

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notif_alertes"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_alerts"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notif_reservations"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_reservations"
                android:layout_marginBottom="12dp" />

            <androidx.appcompat.widget.SwitchCompat
                android:id="@+id/switch_notif_ecocoins"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/notif_ecocoins" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</LinearLayout>