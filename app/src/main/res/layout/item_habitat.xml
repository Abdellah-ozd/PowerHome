<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/layout_floor_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="12dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ETAGE"
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="#888"
            android:layout_marginEnd="8dp"/>

        <TextView
            android:id="@+id/tv_floor_number"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:text="1"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:background="@drawable/bg_floor_square"
            android:gravity="center"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_resident_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/layout_floor_container"
        android:layout_alignParentStart="true"
        android:text="Nom Prénom"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000"
        android:layout_marginBottom="6dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_below="@id/tv_resident_name"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/layout_floor_container">

        <TextView
            android:id="@+id/tv_appliances_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 équipements"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:id="@+id/ll_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
        </LinearLayout>

    </LinearLayout>

</RelativeLayout>