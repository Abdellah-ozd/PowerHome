<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@color/white">

    <LinearLayout
        android:id="@+id/layout_floor"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true">

        <TextView
            android:id="@+id/tv_floor_number"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="1"
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="#333"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="ETAGE"
            android:textSize="10sp"
            android:textColor="#888"/>
    </LinearLayout>

    <TextView
        android:id="@+id/tv_resident_name"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_toStartOf="@id/layout_floor"
        android:layout_alignParentStart="true"
        android:text="Nom Prénom"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="#000"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_below="@id/tv_resident_name"
        android:layout_alignParentStart="true"
        android:layout_toStartOf="@id/layout_floor">

        <TextView
            android:id="@+id/tv_appliances_count"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 équipements"
            android:textSize="14sp"
            android:textColor="#666"
            android:layout_marginEnd="8dp"/>

        <LinearLayout
            android:id="@+id/ll_icons_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
        </LinearLayout>

    </LinearLayout>
</RelativeLayout>