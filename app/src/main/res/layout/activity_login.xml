<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:padding="30dp"
    android:background="@color/power_bg"
    tools:context=".LoginActivity">

    <ImageView
        android:id="@+id/logo_login"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:src="@drawable/powerhomelogo"
        app:tint="@color/power_accent"
        android:layout_marginBottom="40dp"
        android:contentDescription="@string/app_name"/>

    <EditText
        android:id="@+id/et_login_email"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/power_input_bg"
        android:hint="@string/login_hint_email"
        android:textColor="@color/white"
        android:textColorHint="#B0BEC5"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:inputType="textEmailAddress"
        android:layout_marginBottom="16dp"/>

    <EditText
        android:id="@+id/et_login_pass"
        android:layout_width="match_parent"
        android:layout_height="55dp"
        android:background="@color/power_input_bg"
        android:hint="@string/login_hint_pass"
        android:textColor="@color/white"
        android:textColorHint="#B0BEC5"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:inputType="textPassword"
        android:layout_marginBottom="24dp"/>

    <Button
        android:id="@+id/btn_login_connect"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_connect"
        android:backgroundTint="@color/power_accent"
        android:textColor="@color/power_bg"
        android:textStyle="bold"
        android:textSize="16sp"
        android:layout_marginBottom="16dp"/>

    <Button
        android:id="@+id/btn_login_forgot"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/btn_forgot"
        style="?android:attr/borderlessButtonStyle"
        android:textColor="@color/power_text_secondary"
        android:layout_marginBottom="10dp"/>

    <Button
        android:id="@+id/btn_login_register"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_register"
        android:backgroundTint="@color/power_input_bg"
        android:textColor="@color/white"/>

    <Button
        android:id="@+id/btn_login_social"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/btn_social"
        android:backgroundTint="#3b5998"
        android:textColor="@color/white"
        android:layout_marginTop="16dp"/>

</LinearLayout>