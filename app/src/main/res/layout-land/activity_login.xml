<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:background="@color/power_bg"
    android:padding="20dp"
    android:baselineAligned="false"
    tools:context=".LoginActivity">

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_vertical"
        android:paddingEnd="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Identifiez-vous"
            android:textColor="@color/power_text_dark"
            android:textStyle="bold"
            android:textSize="18sp"
            android:layout_marginBottom="16dp"/>

        <EditText
            android:id="@+id/et_login_email"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/power_input_bg"
            android:hint="@string/login_hint_email"
            android:textColor="@color/power_text_dark"
            android:paddingStart="16dp"
            android:inputType="textEmailAddress"
            android:layout_marginBottom="10dp"/>

        <EditText
            android:id="@+id/et_login_pass"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@color/power_input_bg"
            android:hint="@string/login_hint_pass"
            android:textColor="@color/power_text_dark"
            android:paddingStart="16dp"
            android:inputType="textPassword"
            android:layout_marginBottom="5dp"/>

        <Button
            android:id="@+id/btn_login_forgot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/btn_forgot"
            style="?android:attr/borderlessButtonStyle"
            android:textColor="@color/power_orange"
            android:textSize="12sp"
            android:layout_gravity="end"
            android:layout_marginBottom="10dp"/>

        <Button
            android:id="@+id/btn_login_connect"
            android:layout_width="match_parent"
            android:layout_height="55dp"
            android:text="@string/btn_connect"
            android:backgroundTint="@color/power_blue"
            android:textColor="@color/white"
            android:textStyle="bold"/>

    </LinearLayout>

    <View
        android:layout_width="1dp"
        android:layout_height="match_parent"
        android:background="#CCCCCC"
        android:layout_marginTop="20dp"
        android:layout_marginBottom="20dp"/>

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nouveau sur PowerHome ?"
            android:textColor="@color/power_text_dark"
            android:layout_marginBottom="8dp"/>

        <Button
            android:id="@+id/btn_login_register"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_register"
            android:textColor="@color/white"
            android:backgroundTint="@color/power_orange"
            android:textStyle="bold"
            android:layout_marginBottom="24dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="OU"
            android:textColor="#999999"
            android:layout_marginBottom="24dp"/>

        <Button
            android:id="@+id/btn_login_social"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/btn_social"
            android:backgroundTint="#3b5998"
            android:textColor="@color/white"
            app:icon="@drawable/ic_facebook"
            app:iconTint="@null"
            app:iconPadding="10dp"
            app:iconGravity="textStart"
            android:layout_marginTop="5dp"/>

    </LinearLayout>

</LinearLayout>